[Unit]
Description=Main website
After=network.target

[Service]
WorkingDirectory=/srv/website/SuperDyl-Website

User=website
Group=website

Restart=always

ExecStart=/usr/bin/npm run serve -- -p 3019 --buildScript microvisor-build.sh --runScript microvisor-run.sh --secret 'SOME_SECRET'

StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=website

[Install]
WantedBy=multi-user.target
